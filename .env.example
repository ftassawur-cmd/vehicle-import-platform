# ── Database ──
DATABASE_URL=postgresql://jsl:jsl@localhost:5432/jsl_imports

# ── Auth (Phase 5) ──
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
ARGON2_MEMORY_KIB=65536

# ── App ──
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
NODE_ENV=development

# ── Mail (verification / reset) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="JSL Imports <no-reply@jslimports.lk>"

# ── FX ingestion (Phase 4 job) ──
FX_FEED_URL=
FX_STALE_AFTER_HOURS=168

# ── API server (apps/api) ──
PORT=3000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# One-off seed (apps/api/prisma/seed.ts) — override before seeding anything real
SEED_ADMIN_EMAIL=admin@jslimports.lk
SEED_ADMIN_PASSWORD=ChangeMe123!
