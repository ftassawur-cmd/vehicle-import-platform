{
  "name": "@jsl/api",
  "private": true,
  "version": "0.1.0",
  "description": "JSL Imports \u2014 NestJS API. Authoritative calc runs, versioned rule publishing, auth/RBAC, quotations, audit.",
  "scripts": {
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "db:migrate:dev": "prisma migrate dev --config ../../prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config ../../prisma.config.ts",
    "db:migrate:diff": "prisma migrate diff --config ../../prisma.config.ts --from-migrations ../../prisma/migrations --to-schema ../../prisma/schema.prisma --shadow-database-url \"$SHADOW_DATABASE_URL\" --exit-code",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --watch -r ts-node/register/transpile-only src/main.ts",
    "start": "node dist/main.js",
    "e2e": "tsx test/e2e.ts",
    "build:engine": "npm --prefix ../../packages/calc-engine run build",
    "prebuild": "npm run build:engine",
    "predev": "npm run build:engine",
    "pree2e": "npm run build:engine"
  },
  "dependencies": {
    "@jsl/calc-engine": "file:../../packages/calc-engine",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "nodemailer": "^7.0.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}